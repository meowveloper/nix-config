alias ls='eza -l --color=auto --group-directories-first --icons=auto'
alias la='eza -la --color=auto --group-directories-first --icons=auto'
alias l='eza -laa --color=auto --group-directories-first --icons=auto'
alias tree='eza --tree'

alias nn='nvim .'
alias n='nvim'

alias gg='lazygit'

alias cat='bat'
alias grep='rg'
alias find='fd'

alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias df='duf'

# Cloud Mounts
alias mount-secret='systemctl --user start rclone-secret.service'
alias umount-secret='systemctl --user stop rclone-secret.service'
alias mount-gdrive='systemctl --user start rclone-gdrive.service'
alias umount-gdrive='systemctl --user stop rclone-gdrive.service'
alias umount-cloud='systemctl --user stop rclone-secret.service rclone-gdrive.service'
