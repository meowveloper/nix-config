layout {
    focus-ring {
        width 2
        active-color "{{colors.primary.default.hex}}20"
        inactive-color "{{colors.surface_container.default.hex}}20"
    }
    shadow {
        on
        softness 30
        spread 5
        offset x=0 y=5
        draw-behind-window true
        color "#00000070"
    }
}
